{
  "name": "statfoundry",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "start:service": "cd service && uvicorn src.app:app --reload",
    "start:ui": "cd ui && npm start",
    "dev": "concurrently \"npm run start:service\" \"npm run start:ui\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "use-debounce": "^10.0.5"
  }
}
