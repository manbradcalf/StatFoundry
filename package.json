{
  "name": "statfoundry",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "start:service": "PYTHONPATH=./service uvicorn src.app:app --host 0.0.0.0 --port 5001 --reload",
    "start:ui": "cd ui && npm start",
    "start:ui:prod": "cd ui && npm run start",
    "build:ui": "cd ui && npm run build",
    "dev": "concurrently \"npm run start:service\" \"npm run start:ui\"",
    "start": "concurrently \"npm run start:service\" \"npm run start:ui:prod\"",
    "build": "npm run build:ui",
    "lint": "cd ui && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  }
} 